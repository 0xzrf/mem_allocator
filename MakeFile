MODULES = src/malloc.c
OUT = exec/exec
CC = gcc
CFLAGS = -O2 -Iinclude -Wall -Wextra -Werror

build:
	mkdir -p exec
	$(CC) $(CFLAGS) -o $(OUT) examples/normal_allocation.c $(MODULES)

build_and_run_ex: build
	./$(OUT)

TEST_OUT = exec/test_exec
TEST_MODULES = tests/unit/test_chunk.c tests/test_runner/run_tests.c tests/unity/unity.c

test:
	$(CC) $(CFLAGS) -o $(TEST_OUT) $(TEST_MODULES) && ./$(TEST_OUT)
